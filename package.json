{
  "name": "copilot-chat-export",
  "displayName": "Copilot Chat Export",
  "description": "Preview or save the focused Copilot chat as a self-contained HTML page in VS Code.",
  "version": "1.0.5",
  "publisher": "local",
  "repository": {
    "type": "git",
    "url": "https://github.com/benmartens/copilot-chat-export"
  },
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "chatTranscriptHtmlPreview.customizeActiveChatAsHtml",
        "title": "Customize Active Chat as HTML...",
        "category": "Chat Transcript"
      },
      {
        "command": "chatTranscriptHtmlPreview.exportActiveChatToHtml",
        "title": "Preview Active Chat as HTML",
        "category": "Chat Transcript"
      },
      {
        "command": "chatTranscriptHtmlPreview.exportActiveChatToHtmlSaveAs",
        "title": "Save Active Chat to HTML As...",
        "category": "Chat Transcript"
      }
    ],
    "configuration": {
      "title": "Chat Transcript HTML Preview",
      "properties": {
        "chatTranscriptHtmlPreview.generateSummary": {
          "type": "boolean",
          "default": true,
          "description": "Use AI to generate a short title (5 words or fewer) and summary near the top of the exported HTML."
        },
        "chatTranscriptHtmlPreview.openTarget": {
          "type": "string",
          "enum": [
            "vscode",
            "external"
          ],
          "default": "vscode",
          "description": "Where to open exported HTML. 'vscode' opens in an in-editor preview. 'external' opens the saved file in your default browser."
        },
        "chatTranscriptHtmlPreview.builderDefaults.thinkingMode": {
          "type": "string",
          "enum": [
            "hidden",
            "collapsed",
            "shown"
          ],
          "default": "hidden",
          "description": "Default detail level for assistant thinking and tool activity in exports."
        },
        "chatTranscriptHtmlPreview.builderDefaults.includeSummary": {
          "type": "boolean",
          "default": true,
          "description": "Default whether the export includes the generated title and summary block."
        },
        "chatTranscriptHtmlPreview.builderDefaults.includeMetadata": {
          "type": "boolean",
          "default": true,
          "description": "Default whether the export includes the metadata header."
        },
        "chatTranscriptHtmlPreview.builderDefaults.includeCodeBlocks": {
          "type": "boolean",
          "default": true,
          "description": "Default whether fenced code blocks are included in exported HTML."
        },
        "chatTranscriptHtmlPreview.builderDefaults.includeLinks": {
          "type": "boolean",
          "default": true,
          "description": "Default whether links remain clickable in exported HTML."
        },
        "chatTranscriptHtmlPreview.builderDefaults.theme": {
          "type": "string",
          "enum": [
            "system",
            "light",
            "dark"
          ],
          "default": "system",
          "description": "Default theme for exported HTML."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "prepackage:vsix": "npm run compile",
    "package:vsix": "vsce package",
    "install:local": "node -e \"const{name,version}=require('./package.json');require('child_process').execSync('code --install-extension '+name+'-'+version+'.vsix --force',{stdio:'inherit'})\"",
    "refresh:local": "npm run package:vsix && npm run install:local"
  },
  "devDependencies": {
    "@types/marked": "^4.3.2",
    "@types/node": "^20.17.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.7.2"
  },
  "dependencies": {
    "marked": "^4.3.0"
  }
}
